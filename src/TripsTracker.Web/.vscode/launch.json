{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "localhost (Edge)",
      "type": "edge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}\\public"
    },
    {
      "name": "localhost (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}\\public"
    },
    {
      "name": "Launch Vite Dev Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/vite",
      "stopOnEntry": false
    }
  ],
  "compounds": [
    {
      "name": "Launch Vite and Browser",
      "configurations": [
        "Launch Vite Dev Server",
        "localhost (Edge)"
      ]
    }
  ]
}
