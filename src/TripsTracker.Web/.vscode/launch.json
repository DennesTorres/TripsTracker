{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "localhost (Edge)",
      "type": "edge",
      "request": "launch",
      "url": "http://localhost:4173",
      "webRoot": "${workspaceFolder}\\public"
    },
    {
      "name": "localhost (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4173",
      "webRoot": "${workspaceFolder}\\public"
    },
    {
      "name": "Launch Vite Preview",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/vite",
      "args": ["preview"],
      "stopOnEntry": false
    }
  ],
  "compounds": [
    {
      "name": "Launch Preview and Browser",
      "configurations": [
        "Launch Vite Preview",
        "localhost (Edge)"
      ]
    }
  ]
}
